BEATFORGE_HOST=127.0.0.1
BEATFORGE_API_PORT=8000
BEATFORGE_WEB_PORT=5173
# Override only when the browser origin is managed outside the task runner:
# BEATFORGE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BEATFORGE_DATABASE_URL=sqlite:///./storage/beatforge.db
BEATFORGE_STORAGE_DIR=./storage
BEATFORGE_MAX_UPLOAD_BYTES=262144000
BEATFORGE_DEMUCS_MODEL=htdemucs
BEATFORGE_DEMUCS_DEVICE=auto
BEATFORGE_QWEN_ASR_MODEL=./storage/models/Qwen3-ASR-1.7B
BEATFORGE_QWEN_ALIGNER_MODEL=./storage/models/Qwen3-ForcedAligner-0.6B
BEATFORGE_QWEN_DEVICE=auto
VITE_API_BASE_URL=/api
